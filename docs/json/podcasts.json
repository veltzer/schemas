{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "podcasts.json",
	"description": "Podcasts that I listened to",
	"type": "object",
	"properties": {
		"$schema": {
			"$ref": "https://veltzer.github.io/schemas/json/shared/common.json#/$defs/$schema"
		},
		"items": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"name": {
						"$ref": "https://veltzer.github.io/schemas/json/shared/common.json#/$defs/name"
					},
					"url": {
						"$ref": "https://veltzer.github.io/schemas/json/shared/common.json#/$defs/url"
					},
					"rss_feed": {
						"description": "RSS feed URL for the podcast",
						"type": "string",
						"format": "uri"
					},
					"chapters": {
						"description": "Chapters/episodes of the podcast that I listened to",
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"title": {
									"description": "Episode title from the RSS feed",
									"type": "string"
								},
								"description": {
									"description": "Episode description from the RSS feed",
									"type": "string"
								},
								"pubDate": {
									"description": "Episode publication date from the RSS feed",
									"type": "string"
								},
								"episode": {
									"description": "Episode number from the RSS feed",
									"type": ["integer", "null"]
								},
								"duration": {
									"description": "Episode duration in seconds",
									"type": "integer"
								},
								"episodeType": {
									"description": "Episode type from the RSS feed (full, trailer, bonus)",
									"type": "string",
									"enum": ["full", "trailer", "bonus"]
								},
								"explicit": {
									"description": "Whether the episode is explicit",
									"type": "string"
								},
								"enclosure_url": {
									"description": "URL to the episode audio file",
									"type": "string"
								},
								"image": {
									"description": "URL to the episode artwork",
									"type": "string"
								},
								"author": {
									"description": "Episode author from the RSS feed",
									"type": "string"
								},
								"guid": {
									"description": "Unique episode identifier from the RSS feed",
									"type": "string"
								},
								"date_utcz": {
									"$ref": "https://veltzer.github.io/schemas/json/shared/dates.json#/$defs/date_utcz"
								},
								"date_timezone": {
									"$ref": "https://veltzer.github.io/schemas/json/shared/dates.json#/$defs/date_timezone"
								},
								"location": {
									"$ref": "https://veltzer.github.io/schemas/json/shared/location.json#/$defs/location"
								},
								"device": {
									"$ref": "https://veltzer.github.io/schemas/json/shared/device.json#/$defs/device"
								},
								"rating": {
									"$ref": "https://veltzer.github.io/schemas/json/shared/common.json#/$defs/rating"
								},
								"review": {
									"$ref": "https://veltzer.github.io/schemas/json/shared/common.json#/$defs/review"
								}
							},
							"required": [
								"title",
								"date_utcz",
								"date_timezone",
								"device"
							],
							"propertyOrdering": [
								"title",
								"description",
								"pubDate",
								"episode",
								"duration",
								"episodeType",
								"explicit",
								"enclosure_url",
								"image",
								"author",
								"guid",
								"date_utcz",
								"date_timezone",
								"location",
								"device",
								"rating",
								"review"
							],
							"additionalProperties": false
						}
					},
					"rating": {
						"$ref": "https://veltzer.github.io/schemas/json/shared/common.json#/$defs/rating"
					},
					"review": {
						"$ref": "https://veltzer.github.io/schemas/json/shared/common.json#/$defs/review"
					},
					"internal_id": {
						"description": "Internal unique ID for each podcast",
						"type": "number"
					}
				},
				"required": [
					"name",
					"chapters"
				],
				"propertyOrdering": [
					"name",
					"url",
					"rss_feed",
					"chapters",
					"rating",
					"review",
					"internal_id"
				],
				"additionalProperties": false
			}
		}
	},
	"required": ["items"],
	"additionalProperties": false
}
